{
    "name": "dsfeventtracker",
    "version": "1.3.1",
    "description": "Front end of the DSF Event Tracker Alt1 plugin.",
    "homepage": "https://www.dsfeventtracker.com/",
    "bugs": {
        "url": "https://github.com/LukeHankey/DSF-Event-Tracker/issues"
    },
    "license": "MIT",
    "author": "Luke Hankey",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/LukeHankey/DSF-Event-Tracker.git"
    },
    "engines": {
        "node": ">=24",
        "npm": ">=11"
    },
    "scripts": {
        "build": "webpack --env VERSION=alt1 && npm run postbuild",
        "build:dev": "webpack --env VERSION=alt1-dev && npm run postbuild",
        "build:local": "webpack --env VERSION=alt1-local && npm run postbuild",
        "postbuild": "cp index.md _config.yml README.md favicon.ico CNAME robots.txt package.json dist/ && cp -r faq _includes dist/",
        "watch": "webpack --env VERSION=alt1-local --watch",
        "deploy": "gh-pages -d dist",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
        "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx}\"",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "alt1": "^0.1.3",
        "axios": "^1.18.1",
        "fuse.js": "^7.5.0",
        "tesseract.js": "^6.0.1",
        "uuid": "^14.0.1"
    },
    "devDependencies": {
        "@eslint/css": "^1.3.0",
        "@eslint/eslintrc": "^3.3.6",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^2.0.1",
        "@eslint/markdown": "^6.4.0",
        "@types/node": "^25.9.3",
        "copy-webpack-plugin": "^13.0.0",
        "css-loader": "^7.1.4",
        "eslint": "^10.7.0",
        "express": "^4.21.2",
        "gh-pages": "^6.3.0",
        "globals": "^17.7.0",
        "html-webpack-plugin": "^5.6.7",
        "prettier": "^3.9.5",
        "sharp": "^0.35.3",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.6.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.64.0",
        "webpack": "^5.108.4",
        "webpack-cli": "^7.2.1"
    },
    "allowScripts": {
        "tesseract.js@6.0.1": true
    }
}
